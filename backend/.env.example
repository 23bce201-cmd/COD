# Database
DATABASE_URL=postgresql://user:password@localhost:5432/cloudcrm

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=cloudcrm
KEYCLOAK_CLIENT_ID=cloudcrm-frontend
KEYCLOAK_AUDIENCE=cloudcrm-frontend
KEYCLOAK_ISSUER=http://localhost:8080/realms/cloudcrm
KEYCLOAK_JWKS_URL=http://localhost:8080/realms/cloudcrm/protocol/openid-connect/certs

# Keycloak admin provisioning
KEYCLOAK_ADMIN_REALM=cloudcrm
KEYCLOAK_ADMIN_CLIENT_ID=cloudcrm-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=change-me

# AES-256-GCM encryption for platform credentials
AES_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
AES_IV_LENGTH=12

# CORS
FRONTEND_ORIGIN=http://localhost:5173
PUBLIC_API_ORIGIN=http://localhost:3001

# Gmail OAuth app credentials for user-owned report sending
GMAIL_CLIENT_ID=your_google_oauth_client_id
GMAIL_CLIENT_SECRET=your_google_oauth_client_secret
GMAIL_REDIRECT_URI=http://localhost:3001/api/reports/email/gmail/callback
# In development, emails are logged unless this is explicitly false.
GMAIL_SEND_DISABLED=true

# Email (legacy SMTP placeholders)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=noreply@cloudcrm.app
EMAIL_PASS=your_email_password

# Server
PORT=3001
NODE_ENV=development
